# ── App ──────────────────────────────────────────
APP_NAME=JobRadar AI
DEBUG=true

# ── MongoDB ──────────────────────────────────────
# Local Mongo or your MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017
MONGO_DB=jobradar

# ── JWT ──────────────────────────────────────────
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM (used from Week 2) ───────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── External (used later) ────────────────────────
TAVILY_API_KEY=
PINECONE_API_KEY=
