# ── App ──────────────────────────────────────────
APP_NAME=JobRadar AI
DEBUG=true

# ── MongoDB ──────────────────────────────────────
MONGO_DB=jobradar

# Option A — simple local dev (no auth):
MONGO_URI=mongodb://localhost:27017

# Option B — VPS / local Mongo with auth (leave MONGO_URI unset or empty; set these instead):
# MONGO_HOST=localhost
# MONGO_USER=your_mongo_user
# MONGO_PASSWORD=your_mongo_password

# Option C — MongoDB Atlas (full connection string):
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── LLM (used from Week 2) ───────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── External (used later) ────────────────────────
TAVILY_API_KEY=
PINECONE_API_KEY=

# ── Auto Scheduler ───────────────────────────────
AUTO_CRAWL_INTERVAL_HOURS=12

# ── Admin / Freemium (REQUIRED for admin panel) ──
# Put real secret values here ONLY. Never commit real secrets.
ADMIN_EMAIL=saimkaskar1@gmail.com
ADMIN_SECRET_PATH=change-this-to-a-random-long-string   # e.g. k9x7p2mQvL4r

# Free tier daily limits
FREE_SEARCH_LIMIT=3
FREE_RATING_LIMIT=10

# Note: For LLM models, set them via OLLAMA_MODEL / OPENAI_MODEL / XAI_MODEL / GROK_MODEL / RATING_MODEL in .env
# No models are hardcoded in the code.
