# ── App ──────────────────────────────────────────
APP_NAME=JobRadar AI
DEBUG=true
# Public URL of the React app — used in password reset + job reminder emails
FRONTEND_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────
MONGO_DB=jobradar

# Option A — simple local dev (no auth):
MONGO_URI=mongodb://localhost:27017

# Option B — VPS / local Mongo with auth (leave MONGO_URI unset or empty; set these instead):
# MONGO_HOST=localhost
# MONGO_USER=your_mongo_user
# MONGO_PASSWORD=your_mongo_password

# Option C — MongoDB Atlas (full connection string):
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
PASSWORD_RESET_EXPIRE_MINUTES=60
FRONTEND_URL=http://localhost:5173

# Optional SMTP for password reset + high-score job reminder emails
# (if unset, reset link prints in backend logs when DEBUG=true; reminders are skipped)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=JobRadar
# SMTP_REPLY_TO=support@yourdomain.com
# SMTP_USE_TLS=true
#
# Gmail personal accounts: inbox shows SMTP_USER unless you add SMTP_FROM_EMAIL
# under Gmail → Settings → Accounts → "Send mail as" (needs DNS on your domain).
# For production, prefer Resend/SendGrid/SES with a verified saimjs.com domain.

# ── LLM (used from Week 2) ───────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Job crawlers (required for search) ───────────
JOOBLE_API_KEY=
# RapidAPI jobs-api14 — Indeed + LinkedIn (Glassdoor not on this API)
JOBSAPI_KEY=

# ── External (optional) ──────────────────────────
TAVILY_API_KEY=
PINECONE_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Auto Scheduler ───────────────────────────────
AUTO_CRAWL_INTERVAL_HOURS=24
# Max new jobs stored per user per automatic crawl cycle (does not use manual search quota)
AUTO_CRAWL_MAX_STORED_PER_CYCLE=25

# High-score job apply reminders (requires SMTP in production)
JOB_REMINDER_ENABLED=true
JOB_REMINDER_MIN_SCORE=8
JOB_REMINDER_MIN_JOBS=2
JOB_REMINDER_MAX_PER_DAY=2
JOB_REMINDER_EMAIL_JOB_LIMIT=8
JOB_REMINDER_HOURS_UTC=8,18

# ── Admin / Freemium (REQUIRED for admin panel) ──
# Put real secret values here ONLY. Never commit real secrets.
ADMIN_EMAIL=your-admin@example.com
ADMIN_SECRET_PATH=change-this-to-a-random-long-string   # e.g. k9x7p2mQvL4r

# Free tier daily limits
FREE_SEARCH_LIMIT=3
FREE_RATING_LIMIT=10
# Per-user AI token caps (free tier defaults; 0 = unlimited). Admin can override per user.
FREE_DAILY_TOKEN_LIMIT=250000
FREE_MONTHLY_TOKEN_LIMIT=0

# AI usage in admin panel (optional — set your own rates for your provider/model)
# AI_MONTHLY_BUDGET_USD=
# AI_COST_PER_1K_PROMPT_TOKENS=
# AI_COST_PER_1K_COMPLETION_TOKENS=
# AI_COST_PER_1K_EMBEDDING_TOKENS=

# Note: For LLM models, set them via OLLAMA_MODEL / OPENAI_MODEL / XAI_MODEL / GROK_MODEL / RATING_MODEL in .env
# No models are hardcoded in the code.
